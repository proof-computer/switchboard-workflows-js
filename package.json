{
  "name": "@proof-computer/switchboard-workflows",
  "version": "0.1.4",
  "description": "Executor-neutral Switchboard deployment workflows and host-side helpers.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/proof-computer/switchboard-workflows-js.git"
  },
  "type": "module",
  "main": "dist/workflows.js",
  "types": "dist/workflows.d.ts",
  "exports": {
    ".": {
      "types": "./dist/workflows.d.ts",
      "import": "./dist/workflows.js"
    },
    "./workflows": {
      "types": "./dist/workflows.d.ts",
      "import": "./dist/workflows.js"
    },
    "./control-plane": {
      "types": "./dist/control-plane.d.ts",
      "import": "./dist/control-plane.js"
    },
    "./funding": {
      "types": "./dist/funding.d.ts",
      "import": "./dist/funding.js"
    },
    "./network-manifest": {
      "types": "./dist/network-manifest.d.ts",
      "import": "./dist/network-manifest.js"
    },
    "./report-signing": {
      "types": "./dist/report-signing.d.ts",
      "import": "./dist/report-signing.js"
    },
    "./service-catalog": {
      "types": "./dist/service-catalog.d.ts",
      "import": "./dist/service-catalog.js"
    },
    "./service-discovery": {
      "types": "./dist/service-discovery.d.ts",
      "import": "./dist/service-discovery.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "npm run build && node --test tests/*.test.mjs",
    "prepare": "npm run build",
    "pack:dry-run": "npm pack --dry-run --json"
  },
  "dependencies": {
    "@polkadot/keyring": "^14.0.3",
    "@polkadot/util": "^14.0.3",
    "@polkadot/util-crypto": "^14.0.3",
    "ethers": "^6.15.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "UNLICENSED",
  "publishConfig": {
    "access": "public"
  }
}
